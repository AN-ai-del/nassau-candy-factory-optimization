# =====================================================
# Nassau Candy Factory Optimization
# .gitignore
# =====================================================

# -------------------------------
# Python
# -------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo

# -------------------------------
# Virtual Environments
# -------------------------------
.venv/
venv/
env/
ENV/

# -------------------------------
# Jupyter Notebook
# -------------------------------
.ipynb_checkpoints/

# -------------------------------
# Streamlit
# -------------------------------
.streamlit/secrets.toml

# -------------------------------
# Environment Variables
# -------------------------------
.env
.env.*
!.env.example

# -------------------------------
# VS Code
# -------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# -------------------------------
# Operating System Files
# -------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -------------------------------
# Logs
# -------------------------------
*.log
logs/

# -------------------------------
# Build & Distribution
# -------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# -------------------------------
# Testing
# -------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -------------------------------
# Type Checking
# -------------------------------
.mypy_cache/
.pytype/
.pyre/

# -------------------------------
# Ruff / Linting
# -------------------------------
.ruff_cache/

# -------------------------------
# IDE
# -------------------------------
.idea/

# -------------------------------
# Temporary Files
# -------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# -------------------------------
# Model Checkpoints
# (Uncomment if you generate large checkpoints)
# -------------------------------
# checkpoints/
# *.ckpt
# *.h5
# *.onnx

# -------------------------------
# Data Files (Optional)
# Keep commented if you want to version datasets.
# -------------------------------
# data/raw/
# data/processed/

# -------------------------------
# Reports (Optional)
# Keep generated reports under version control if desired.
# -------------------------------
# reports/figures/
# reports/executive_summary/

# -------------------------------
# Miscellaneous
# -------------------------------
.cache/